  "keywords": [
    "link",
    "hardlink",
    "fs"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "author": "Zoltan Kochan <z@kochan.io> (https://www.kochan.io/)",
  "license": "MIT",
  "homepage": "https://github.com/zkochan/packages/tree/main/root-link-target#readme",
  "dependencies": {
    "can-link": "workspace:^",
    "next-path": "^1.0.0",
    "path-temp": "workspace:^"
  },
  "devDependencies": {
    "mos": "2.0.0-alpha.3",
    "mos-plugin-readme": "^1.0.4",
    "standard": "^17.1.2"
  },
  "mos": {
